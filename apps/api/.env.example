# Required
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL="mysql://app:apppw@localhost:3306/ecommerce"
# Needed only by `prisma migrate dev` to create/drop a temporary shadow database.
# Uses root because the `app` user only has privileges on `ecommerce`.
SHADOW_DATABASE_URL="mysql://root:rootpw@localhost:3306/ecommerce_shadow"

# Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=replace-me-with-32+bytes-base64
JWT_REFRESH_SECRET=replace-me-with-32+bytes-base64-different

# Token lifetimes (seconds)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Rate limiting
RATE_LIMIT_STORE=memory

# Logging
LOG_LEVEL=info
