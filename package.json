{
  "name": "ai-blueprint-ecommerce",
  "version": "0.1.0",
  "private": true,
  "description": "AI-orchestrated full-stack eCommerce platform generated from an AI Blueprint (initial.md + guidelines + capabilities).",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @app/api db:migrate",
    "db:seed": "pnpm --filter @app/api db:seed",
    "setup": "pnpm install && pnpm db:up && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
