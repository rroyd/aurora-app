{
  "info": {
    "name": "Aurora eCommerce API",
    "description": "Curated collection covering the full eCommerce flow. Variables: `{{baseUrl}}` (default http://localhost:4000), `{{accessToken}}` is captured automatically by Login/Register.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "accessToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "productSlug", "value": "aurora-wireless-headphones" },
    { "key": "orderId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 — Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer-{{$timestamp}}@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"Demo\",\n  \"lastName\": \"User\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (seed user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@shop.dev\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accessToken', pm.response.json().accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "me"] }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "02 — Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/products?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "products"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "q", "value": "", "disabled": true },
                { "key": "category", "value": "", "disabled": true },
                { "key": "minPrice", "value": "1000", "disabled": true },
                { "key": "maxPrice", "value": "50000", "disabled": true },
                { "key": "sort", "value": "newest", "disabled": true },
                { "key": "cursor", "value": "", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const items = pm.response.json().items;",
                  "  if (items.length) {",
                  "    pm.collectionVariables.set('productId', items[0].id);",
                  "    pm.collectionVariables.set('productSlug', items[0].slug);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/products/categories",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "products", "categories"]
            }
          }
        },
        {
          "name": "Product detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/products/{{productSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "products", "{{productSlug}}"]
            }
          }
        }
      ]
    },
    {
      "name": "03 — Cart",
      "item": [
        {
          "name": "Get cart",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/cart", "host": ["{{baseUrl}}"], "path": ["v1", "cart"] }
          }
        },
        {
          "name": "Add item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/cart/items", "host": ["{{baseUrl}}"], "path": ["v1", "cart", "items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Update item quantity",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/cart/items/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "cart", "items", "{{productId}}"]
            },
            "body": { "mode": "raw", "raw": "{ \"quantity\": 5 }" }
          }
        },
        {
          "name": "Remove item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/v1/cart/items/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "cart", "items", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "04 — Orders",
      "item": [
        {
          "name": "Place order (test card 4242…)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/orders", "host": ["{{baseUrl}}"], "path": ["v1", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"firstName\": \"Demo\",\n    \"lastName\": \"User\",\n    \"line1\": \"1 Main St\",\n    \"city\": \"Tel Aviv\",\n    \"region\": \"TA\",\n    \"postalCode\": \"6100000\",\n    \"country\": \"IL\",\n    \"phone\": \"+972-50-0000000\"\n  },\n  \"card\": {\n    \"number\": \"4242424242424242\",\n    \"expMonth\": 12,\n    \"expYear\": 2030,\n    \"cvc\": \"123\",\n    \"holderName\": \"Demo User\"\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('orderId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/orders", "host": ["{{baseUrl}}"], "path": ["v1", "orders"] }
          }
        },
        {
          "name": "Order detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "05 — Users",
      "item": [
        {
          "name": "Update profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v1", "users", "me"] },
            "body": { "mode": "raw", "raw": "{ \"firstName\": \"Demo\", \"lastName\": \"Updated\" }" }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/v1/users/me/password",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "me", "password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{ \"currentPassword\": \"Password123!\", \"newPassword\": \"BrandNewPass456!\" }"
            }
          }
        }
      ]
    }
  ]
}
